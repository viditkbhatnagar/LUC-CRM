{
  "name": "luc-crm",
  "version": "1.0.0",
  "private": true,
  "description": "LUC CRM — in-house lead-to-admission CRM for Learners Education (Dubai)",
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "start": "node server/src/index.js",
    "seed": "node server/src/seed/seed.js",
    "test": "npm --workspace server run test",
    "sweep": "node server/src/jobs/slaSweep.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
