# ─────────────────────────────────────────────────────────────
# LUC CRM environment — copy to server/.env and fill real values.
# NEVER commit a filled .env. .env is gitignored.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# Database (MongoDB Atlas). Use a dedicated database name per environment.
#   app:   mongodb+srv://<user>:<pass>@<cluster>/luc_crm_dev?retryWrites=true&w=majority
#   tests: mongodb+srv://<user>:<pass>@<cluster>/luc_crm_test?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/luc_crm_dev?retryWrites=true&w=majority
MONGODB_URI_TEST=mongodb+srv://<user>:<pass>@<cluster>/luc_crm_test?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h
COOKIE_SECURE=false           # true in production (https)
CLIENT_ORIGIN=http://localhost:5173

# Integrations
MESSAGING_DRIVER=console       # console (default) | smtp | twilio | meta
STORAGE_DRIVER=stub            # stub (default) | s3
INGEST_API_KEY=replace-with-a-webhook-key
CRON_SECRET=                   # only if the sweep is triggered via HTTP

# AWS S3 (only needed when STORAGE_DRIVER=s3 — install @aws-sdk/client-s3)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Seeding
SEED_ON_BOOT=false

# Run the SLA sweep in-process on a 15-min timer (single always-on service,
# no separate Render cron). Set true on a Starter web service.
RUN_SWEEP_IN_PROCESS=false
